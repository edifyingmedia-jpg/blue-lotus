{
  "id": "Editor",
  "type": "screen",
  "title": "Editor",
  "components": [
    {
      "type": "text",
      "value": "Editor Mode:"
    },
    {
      "type": "dynamicText",
      "binding": "editorState.mode"
    },

    {
      "type": "button",
      "label": "Switch to Design Mode",
      "action": {
        "type": "editorAction",
        "method": "setMode",
        "args": ["design"]
      }
    },
    {
      "type": "button",
      "label": "Switch to Preview Mode",
      "action": {
        "type": "editorAction",
        "method": "setMode",
        "args": ["preview"]
      }
    },
    {
      "type": "button",
      "label": "Switch to Inspect Mode",
      "action": {
        "type": "editorAction",
        "method": "setMode",
        "args": ["inspect"]
      }
    },

    {
      "type": "text",
      "value": "Active Tool:"
    },
    {
      "type": "dynamicText",
      "binding": "editorState.activeTool"
    },

    {
      "type": "button",
      "label": "Select Move Tool",
      "action": {
        "type": "editorAction",
        "method": "selectTool",
        "args": ["move"]
      }
    },
    {
      "type": "button",
      "label": "Select Frame Tool",
      "action": {
        "type": "editorAction",
        "method": "selectTool",
        "args": ["frame"]
      }
    },

    {
      "type": "text",
      "value": "Active Panel:"
    },
    {
      "type": "dynamicText",
      "binding": "editorState.activePanel"
    },

    {
      "type": "button",
      "label": "Open Layers Panel",
      "action": {
        "type": "editorAction",
        "method": "openPanel",
        "args": ["layers"]
      }
    },
    {
      "type": "button",
      "label": "Open Properties Panel",
      "action": {
        "type": "editorAction",
        "method": "openPanel",
        "args": ["properties"]
      }
    },
    {
      "type": "button",
      "label": "Close Panel",
      "action": {
        "type": "editorAction",
        "method": "closePanel"
      }
    },

    {
      "type": "button",
      "label": "Back to Project",
      "action": {
        "type": "goTo",
        "target": "ProjectDetail"
      }
    }
  ]
}
