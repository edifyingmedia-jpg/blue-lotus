{
  "type": "Screen",
  "id": "Account",
  "title": "Account",

  "components": [
    {
      "type": "Text",
      "value": "Your Account",
      "style": "header"
    },

    {
      "type": "Text",
      "value": "Email:",
      "style": "label",
      "marginTop": 16
    },
    {
      "type": "DynamicText",
      "source": "auth.user.email",
      "style": "value"
    },

    {
      "type": "Text",
      "value": "User ID:",
      "style": "label",
      "marginTop": 16
    },
    {
      "type": "DynamicText",
      "source": "auth.user.id",
      "style": "value"
    },

    {
      "type": "Button",
      "label": "Log Out",
      "action": {
        "type": "auth.logout"
      },
      "style": "secondary",
      "marginTop": 32
    }
  ]
}
