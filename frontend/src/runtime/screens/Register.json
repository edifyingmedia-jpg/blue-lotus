{
  "components": [
    {
      "type": "Text",
      "value": "Create Account",
      "size": 28,
      "weight": "bold",
      "align": "center",
      "marginBottom": 24
    },
    {
      "type": "Input",
      "label": "Email",
      "field": "email",
      "placeholder": "you@example.com",
      "marginBottom": 16
    },
    {
      "type": "Input",
      "label": "Password",
      "field": "password",
      "placeholder": "Create a password",
      "secure": true,
      "marginBottom": 24
    },
    {
      "type": "Button",
      "label": "Sign Up",
      "action": {
        "type": "auth.register",
        "emailField": "email",
        "passwordField": "password"
      },
      "style": "primary",
      "marginBottom": 16
    },
    {
      "type": "Button",
      "label": "Already have an account?",
      "action": {
        "type": "navigate",
        "screen": "Login"
      },
      "style": "secondary",
      "marginTop": 20
    }
  ]
}
