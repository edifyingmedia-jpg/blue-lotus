export class ToolRegistry {
  constructor(eventBus, commandManager) {
    this.eventBus = eventBus;
    this.commandManager = commandManager;
    this.tools = new Map();
    this.activeTool = null;
  }

  registerTool(name, toolInstance) {
    this.tools.set(name, toolInstance);
  }

  activateTool(name) {
    const tool = this.tools.get(name);
    if (!tool) {
      console.warn(`Tool not found: ${name}`);
      return;
    }

    this.activeTool = tool;

    if (tool.onActivate) {
      tool.onActivate();
    }

    this.eventBus.emit("tool:activated", { name });
  }

  deactivateTool() {
    if (this.activeTool && this.activeTool.onDeactivate) {
      this.activeTool.onDeactivate();
    }

    this.activeTool = null;
    this.eventBus.emit("tool:deactivated", {});
  }

  handlePointerEvent(event) {
    if (this.activeTool && this.activeTool.handlePointerEvent) {
      this.activeTool.handlePointerEvent(event, this.commandManager);
    }
  }
}
